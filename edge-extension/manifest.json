{
  "manifest_version": 3,
  "name": "ZeroScript Free — Kimi × Roblox Studio Agent",
  "version": "1.0.0",
  "description": "Turn Kimi into a Roblox Studio agent. A clean, robust agentic loop runs right inside the page and drives Roblox Studio through the MCP. No terminal needed.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZeroScript Free"
  },
  "content_scripts": [
    {
      "matches": ["https://www.kimi.com/*", "https://kimi.com/*"],
      "js": ["config.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
