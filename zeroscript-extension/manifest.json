{
  "manifest_version": 3,
  "name": "ZeroScript One × Roblox Studio",
  "version": "1.35.1",
  "description": "ChatGPT Max with reliable composer bootstrap, visible single-screen desktop workspace and one-request Roblox Studio automation.",
  "permissions": ["storage", "clipboardWrite", "notifications"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://deepseek.com/*",
    "https://gemini.google.com/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://chat.z.ai/*",
    "https://chat.qwen.ai/*",
    "https://arena.ai/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.mistral.ai/*",
    "https://raw.githubusercontent.com/*",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": {"service_worker": "background-providers.js"},
  "icons": {"16": "icon.png", "48": "icon.png", "128": "icon.png"},
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZeroScript One",
    "default_icon": {"16": "icon.png", "48": "icon.png", "128": "icon.png"}
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["core/config.js", "core/parser.js", "providers/deepseek.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["core/config.js", "core/parser.js", "providers/gemini.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://www.kimi.com/*", "https://kimi.com/*"],
      "js": ["core/config.js", "core/parser.js", "providers/kimi.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.z.ai/*"],
      "js": ["core/config.js", "core/parser.js", "providers/glm.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://arena.ai/*"],
      "js": ["core/config.js", "core/parser.js", "providers/arena.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["providers/qwen-net.js"], "world": "MAIN", "run_at": "document_start"
    },
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["core/config.js", "core/parser.js", "providers/qwen.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["core/config.js", "core/parser.js", "providers/browser-chat.js", "providers/browser-chat-init-fix.js", "providers/chatgpt-fix.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js", "core/chatgpt-max.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*", "https://copilot.microsoft.com/*", "https://chat.mistral.ai/*"],
      "js": ["core/config.js", "core/parser.js", "providers/browser-chat.js", "providers/browser-chat-init-fix.js", "core/catastrophic-guard.js", "core/permission-guard.js", "core/team-reliability.js", "core/provider-probe.js", "core/main.js", "core/universal-launcher.js"],
      "css": ["overlay.css"], "run_at": "document_idle"
    }
  ]
}